<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAPA FULL SCREEN (base) -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- OVERLAY superior: título + chips flotantes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:paddingTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_map_header">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mapa de Calor"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zonas de mayor incidencia"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="2dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupPeriod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:singleSelection="true"
            app:chipSpacingHorizontal="6dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip24h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24 horas"
                android:textColor="@color/chip_text_color"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipStrokeColor="#80FFFFFF"
                app:chipStrokeWidth="1dp"
                app:checkedIconTint="#FFFFFF"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip7d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 días"
                android:textColor="@color/chip_text_color"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipStrokeColor="#80FFFFFF"
                app:chipStrokeWidth="1dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip30d"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 días"
                android:textColor="@color/chip_text_color"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipStrokeColor="#80FFFFFF"
                app:chipStrokeWidth="1dp"/>

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <!-- LEYENDA inferior flotante -->
    <LinearLayout
        android:id="@+id/legendCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/bg_legend_card"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NIVEL DE RIESGO"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <!-- Alta -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/circle_red"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alto"
                android:textSize="12sp"
                android:textColor="#E0E0E0"/>
        </LinearLayout>

        <!-- Media -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/circle_orange"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medio"
                android:textSize="12sp"
                android:textColor="#E0E0E0"/>
        </LinearLayout>

        <!-- Baja -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/circle_blue"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bajo"
                android:textSize="12sp"
                android:textColor="#E0E0E0"/>
        </LinearLayout>

    </LinearLayout>

    <!-- SIN DATOS toast flotante (centrado) -->
    <TextView
        android:id="@+id/tvNoData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Sin alertas en este período"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:visibility="gone"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@drawable/bg_no_data"/>

</FrameLayout>