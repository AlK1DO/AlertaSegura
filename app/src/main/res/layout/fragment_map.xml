<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_map.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- Encabezado -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mapa de Calor"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A3A5C"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Zonas de mayor incidencia"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Filtro de período -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupPeriod"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip24h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24 horas"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:checked="true"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip7d"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7 días"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip30d"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30 días"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- Mapa (placeholder hasta Fase 4) -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:background="#D6E8F7"
        app:layout_constraintTop_toBottomOf="@id/chipGroupPeriod"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- En Fase 4 aquí irá el MapView con HeatmapTileProvider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="🔥  Mapa de calor&#10;Fase 4"
            android:textSize="18sp"
            android:textColor="#2E6DA4"/>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>