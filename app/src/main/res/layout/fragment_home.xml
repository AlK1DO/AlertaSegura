<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_home.xml -->
<!-- Pantalla principal con el botón SOS -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- ─── Encabezado ──────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hola,"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"/>

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Usuario"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvPremiumBadge"
        android:layout_marginStart="24dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp"/>

    <!-- Badge Premium (visible solo si el usuario tiene plan premium) -->
    <TextView
        android:id="@+id/tvPremiumBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:background="@drawable/badge_premium"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        android:text="⭐ PREMIUM"
        android:textColor="#1A1A2E"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/tvUserName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvUserName" />

    <!-- ─── Contador de alertas restantes ──────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAlertCounter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#252545"
        app:layout_constraintTop_toBottomOf="@id/tvUserName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Ícono alerta -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="20sp"
                android:layout_marginEnd="10dp"/>

            <!-- Texto contador -->
            <TextView
                android:id="@+id/tvAlertCounter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Alertas hoy: 0 / 2"
                android:textSize="13sp"
                android:textColor="#CCCCCC"/>

            <!-- Botón upgrade (solo visible en plan free y cuando quedan pocas alertas) -->
            <TextView
                android:id="@+id/tvUpgradeHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subir a Premium →"
                android:textSize="11sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:visibility="gone"
                android:paddingStart="8dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ─── Instrucción ─────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvSosInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Mantén presionado para activar la alerta"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/viewSosRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp"/>

    <!-- ─── Botón SOS ───────────────────────────────────────────────────────── -->

    <!-- Círculo exterior animado -->

    <!-- Botón SOS principal -->
    <View
        android:id="@+id/viewSosRing"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/circle_sos_ring"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.738" />

    <!-- ─── Card inferior: estado + contactos ──────────────────────────────── -->
    <Button
        android:id="@+id/btnSOS"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/circle_sos_button"
        android:text="SOS"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.72" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardLastAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#252545">

            <!-- Fila principal: estado de alerta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvLastAlertStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sin alertas recientes"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvLastAlertTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#999999"/>

            </LinearLayout>

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333355"/>

            <!-- Fila secundaria: botón ir a Premium (plan free) -->
            <LinearLayout
                android:id="@+id/rowUpgradeToPremium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="¿Necesitas más alertas diarias?"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnGoToPremium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_premium_outline"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="⭐ Ver Premium"
                    android:textColor="#FFD700"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>