<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_community_alert.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFF3F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Fila superior: nombre + tiempo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAlertName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚠️  Juan Pérez"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#B71C1C"/>

            <TextView
                android:id="@+id/tvAlertTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="hace 5 min"
                android:textSize="12sp"
                android:textColor="#999999"/>

        </LinearLayout>

        <!-- DNI parcial -->
        <TextView
            android:id="@+id/tvAlertDni"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DNI: ****5678"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginTop="4dp"/>

        <!-- Ubicación aproximada -->
        <TextView
            android:id="@+id/tvAlertLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Aprox. -12.0123, -77.0456"
            android:textSize="12sp"
            android:textColor="#444444"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>